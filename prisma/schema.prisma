generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  MEMBER
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum Status {
  PLANNING
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

enum Section {
  DEPARTMENT
  OTHER
}

model User {
  id        String   @id @default(cuid())
  name      String   @unique
  email     String   @unique
  password  String?
  role      Role     @default(MEMBER)
  googleId  String?  @unique
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  projectsCreated  Project[] @relation("CreatedProjects")
  projectsAssigned Project[] @relation("AssignedProjects")
  tasksAssigned    Task[]    @relation("AssignedTasks")
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String?
  priority    Priority @default(MEDIUM)
  status      Status   @default(PLANNING)
  section     Section  @default(OTHER)
  visibility  String   @default("private")
  startDate   DateTime
  endDate     DateTime
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  createdById String
  assigneeId  String?
  
  createdBy User @relation("CreatedProjects", fields: [createdById], references: [id])
  assignee  User? @relation("AssignedProjects", fields: [assigneeId], references: [id])
  
  tasks Task[]
}

model Task {
  id          String   @id @default(cuid())
  title       String
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  projectId    String
  assignedToId String?
  
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedTo  User?   @relation("AssignedTasks", fields: [assignedToId], references: [id])
}