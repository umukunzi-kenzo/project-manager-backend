generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")  
}

enum Role {
  ADMIN
  MANAGER
  MEMBER
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String?
  googleId  String?  @unique
  avatar    String?
  role      String   @default("MEMBER")
  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt
}