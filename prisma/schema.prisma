generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  MEMBER
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String?  
  role      Role     @default(MEMBER)
  createdAt DateTime @default(now())
   
  googleId  String?  @unique  // Stores Google's unique ID for this user
  avatar    String?            // Stores profile picture URL from Google
}